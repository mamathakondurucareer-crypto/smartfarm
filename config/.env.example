# SmartFarm OS Configuration
# Copy to .env in the project root and fill in every value before running in production.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SmartFarm OS
APP_VERSION=1.0.0
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — the app will refuse to start without this.
SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Must match your frontend URL exactly.
# Example for local dev: http://localhost:8081,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:8081

# ── Brute-force protection ────────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite:///./smartfarm.db

# Production (PostgreSQL — use a strong password, restrict DB user privileges):
# DATABASE_URL=postgresql://smartfarm_user:STRONG_PASSWORD@localhost:5432/smartfarm

# ── Anthropic AI ──────────────────────────────────────────────────────────────
# Keep this secret — never commit to version control.
ANTHROPIC_API_KEY=

# ── Farm Configuration ────────────────────────────────────────────────────────
FARM_NAME=Nellore Integrated Smart Farm
FARM_LOCATION=Nellore District, Andhra Pradesh
FARM_AREA_ACRES=5
FARM_LAT=14.4426
FARM_LON=79.9865

# ── Alert Thresholds ──────────────────────────────────────────────────────────
DISSOLVED_OXYGEN_CRITICAL=4.0
DISSOLVED_OXYGEN_WARNING=4.5
AMMONIA_CRITICAL=0.05
PH_MIN=6.5
PH_MAX=8.5
GH_TEMP_MAX=38.0
GH_HUMIDITY_MAX=85.0
POULTRY_AMMONIA_MAX=20.0
RESERVOIR_LOW_PCT=25

# ── Market Cities ─────────────────────────────────────────────────────────────
MARKET_CITIES=Hyderabad,Chennai,Vijayawada,Kadapa,Nellore
