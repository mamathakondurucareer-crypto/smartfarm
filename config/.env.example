# SmartFarm OS Configuration
# Copy this to .env in project root and customize

# Application
APP_NAME=SmartFarm OS
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database
# SQLite (development)
DATABASE_URL=sqlite:///./smartfarm.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/smartfarm

# Anthropic AI
ANTHROPIC_API_KEY=your-api-key-here

# Farm Configuration
FARM_NAME=Nellore Integrated Smart Farm
FARM_LOCATION=Nellore District, Andhra Pradesh
FARM_AREA_ACRES=5
FARM_LAT=14.4426
FARM_LON=79.9865

# Alert Thresholds
DISSOLVED_OXYGEN_CRITICAL=4.0
DISSOLVED_OXYGEN_WARNING=4.5
AMMONIA_CRITICAL=0.05
PH_MIN=6.5
PH_MAX=8.5
GH_TEMP_MAX=38.0
GH_HUMIDITY_MAX=85.0
POULTRY_AMMONIA_MAX=20.0
RESERVOIR_LOW_PCT=25

# Market Cities
MARKET_CITIES=Hyderabad,Chennai,Vijayawada,Kadapa,Nellore

# Email Alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=
