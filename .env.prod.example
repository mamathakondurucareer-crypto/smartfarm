# ── Production environment variables (TEMPLATE) ───────────────────────────────
# Copy this to .env.prod and fill in all values.
# .env.prod is in .gitignore — NEVER commit it.
#
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"

# Database
POSTGRES_DB=smartfarm
POSTGRES_USER=smartfarm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# App
SECRET_KEY=CHANGE_ME_RUN_python_secrets_token_hex_32
ALLOWED_ORIGINS=http://localhost:8083
DEBUG=false

# Admin credentials (used by seed_prod.py on first boot)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@smartfarm.in
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# AI
ANTHROPIC_API_KEY=
